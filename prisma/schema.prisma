// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// NOTAS / SUPUESTOS aplicados durante la migración desde el SQL
// ============================================================
// 1. Todas las PK y FK que eran `int` pasaron a `String @db.Uuid`
//    con `@default(uuid())` en las PK (único requisito solicitado).
// 2. `invoice.issue_date` estaba duplicado en el CREATE TABLE original;
//    se dejó una sola vez.
// 3. `service_order.signature_base64` estaba tipado `bigserial` en el SQL
//    (claramente un error); se modeló como `String? @db.Text` (base64).
// 4. `service_order.end_address` estaba tipado `timestamp`; se modeló
//    como `String?` (dirección).
// 5. `office_service.name` estaba tipado `int`; se modeló como `String`.
// 6. `vendor_profile.description` estaba tipado `int`; se modeló como `String?`.
// 7. `warranty_service.purchase_price` estaba tipado `int`; se modeló como
//    `Decimal?` para ser consistente con `selling_price`.
// 8. `ms365_service.email_id` estaba tipado `varchar` pero tiene FK real a
//    `email(id)`; se modeló como UUID (FK).
// 9. `copy_email` y `email_catalog` no tenían PK declarada en el SQL pese a
//    tener columna `id`; se agregó `@id` a ambas.
// 10. `varchar(%)` -> `String`, `decimal(%,%)` -> `Decimal @db.Decimal(19,4)`,
//     `bit(%)` -> `Boolean`.
// ============================================================
// REVISIÓN 2 (correcciones sobre esta versión):
// 11. `User.mail` -> `@unique` (usado para login).
// 12. `UserSession.refreshToken` -> `@unique` (búsqueda de sesión por token).
// 13. Se agregaron `createdAt DateTime @default(now())` y
//     `updatedAt DateTime @updatedAt` a las 44 tablas (auditoría estándar).
// ============================================================

model ActivityServiceOrder {
  id                String @id @default(uuid()) @db.Uuid
  serviceOrderId    String @db.Uuid
  serviceActivityId String @db.Uuid
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  serviceOrder    ServiceOrder    @relation(fields: [serviceOrderId], references: [id])
  serviceActivity ServiceActivity @relation(fields: [serviceActivityId], references: [id])

  @@map("activity_service_order")
}

model AntivirusService {
  id                             String    @id @default(uuid()) @db.Uuid
  name                           String
  url                            String?
  clientProfileId                String    @db.Uuid
  purchasePrice                  Decimal?  @db.Decimal(19, 4)
  sellingPrice                   Decimal?  @db.Decimal(19, 4)
  period                         Int
  expirationDate                 DateTime  @db.Date
  userId                         String    @db.Uuid
  observations                   String?
  emailId                        String?   @db.Uuid
  status                         String
  reason                         String?
  paymentType                    String?
  purchaseInvoiceInvoiceId       String?   @db.Uuid
  purchaseInvoiceVendorProfileId String?   @db.Uuid
  saleInvoiceInvoiceId           String?   @db.Uuid
  saleInvoiceClientProfileId     String?   @db.Uuid
  createdAt                      DateTime @default(now())
  updatedAt                      DateTime @updatedAt

  clientProfile   ClientProfile    @relation(fields: [clientProfileId], references: [id])
  email           Email?           @relation(fields: [emailId], references: [id])
  user            User             @relation(fields: [userId], references: [id])
  purchaseInvoice PurchaseInvoice? @relation(fields: [purchaseInvoiceInvoiceId, purchaseInvoiceVendorProfileId], references: [invoiceId, vendorProfileId])
  saleInvoice     SaleInvoice?     @relation(fields: [saleInvoiceInvoiceId, saleInvoiceClientProfileId], references: [invoiceId, clientProfileId])

  antivirusVendors AntivirusVendor[]

  @@map("antivirus_service")
}

